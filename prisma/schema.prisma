generator client {
  provider = "prisma-client-js"
}

/// * חיבור ישיר ל-Postgres — חובה ל־`prisma db push` / migrate כשמשתמשים ב-Neon pooler
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id                       String                    @id @default(cuid())
  name                     String
  type                     CustomerType              @default(HOME)
  createdAt                DateTime                  @default(now())
  stripeCustomerId         String?                   @unique
  subscriptionStatus       String                    @default("INACTIVE")
  stripeSubscriptionId     String?
  /// סיום ניסיון לתוכנית FREE — null = ארגונים ישנים לפני השדה (ללא הגבלת ניסיון)
  trialEndsAt              DateTime?
  address                  String?
  /// סיווג מס עבור חישובי מע״מ והצגה (ברירת מחדל: עוסק מורשה)
  companyType              CompanyType               @default(LICENSED_DEALER)
  /// ח.פ / ע.מ
  taxId                    String?
  /// true = ארגון מדווח למס (חשבוניות רשמיות); false = ניהול אישי בלבד — מסמכים כמזכר פנימי
  isReportable             Boolean                   @default(true)
  /// שיעור מע״מ באחוזים (ברירת מחדל 18% מ-2025)
  vatRatePercent           Float                     @default(18)
  /// לוח שנה בדשבורד + אפשרות סנכרון Google (הפעלה מדף הגדרות)
  calendarGoogleEnabled    Boolean                   @default(false)
  /// רמת נתונים חיים / יעילות — basic | standard | premium (הרחבות ביטוח ועתיד)
  liveDataTier             String                    @default("basic")
  /// שם משתמש PayPal.Me בלבד (ללא paypal.me/)
  paypalMeSlug             String?
  /// קבלת תשלומים ב-PayPal (עד Pay Plus מלא) — מייל חשבון PayPal
  paypalMerchantEmail      String?
  /// דומיין ציבורי של המנוי (שלב DNS / Vercel Domains — לוגיקת ניתוב בהמשך)
  tenantPublicDomain       String?                   @unique
  /// מיתוג ודף נחיתה: { "landingTitle", "tagline", "primaryColor" } וכו׳
  tenantSiteBrandingJson   Json?
  /// טיוטת הוצאות לביטוח, המלצות חברים, טקסט לשיחה לפני הרשמה — JSON (ממשק חיוב)
  billingWorkspaceJson     Json?
  subscriptionTier         SubscriptionTier          @default(FREE)
  /// יתרת סריקות „זולות” (מנוע Gemini)
  cheapScansRemaining      Int                       @default(10)
  /// יתרת סריקות „פרימיום” (OpenAI / Anthropic)
  premiumScansRemaining    Int                       @default(0)
  /// מקסימום ישויות/חברות תחת המנוי (CORPORATE = ערך גבוה = ללא הגבלה מעשית)
  maxCompanies             Int                       @default(1)
  /// מנוי VIP — דילוג על ניכוי סריקות (ניהול ידני)
  isVip                    Boolean                   @default(false)
  /// API key לאינטגרציית מקאנו (שעון נוכחות / HR) — מוצפן בשרת בלבד
  meckanoApiKey            String?
  /// סנכרון אוטומטי יומי מ-Meckano (cron)
  meckanoAutoSyncEnabled   Boolean                   @default(true)
  meckanoLastSyncAt        DateTime?
  /// סיווג מקצועי — המערכת ממוקדת בענף הבנייה
  industry                 String                    @default("CONSTRUCTION")
  /// הגדרות ספציפיות למקצוע (שדות מותאמים, תוויות וכו')
  industryConfigJson       Json?
  /// התמחות בתוך ענף הבנייה (חשמל, אינסטלציה וכו') — משפיע על פענוח AI והצגה
  constructionTrade        String                    @default("GENERAL_CONTRACTOR")
  activityLogs             ActivityLog[]
  aiCorrections            AICorrection[]
  automations              Automation[]
  cloudIntegrations        CloudIntegration[]
  driveSyncEntries         DriveSyncEntry[]
  contacts                 Contact[]
  contactSearchEmbeddings  ContactSearchEmbedding[]
  knowledgeVaultChunks     KnowledgeVaultChunk[]
  documents                Document[]
  documentLineItems        DocumentLineItem[]
  documentScanCaches       DocumentScanCache[]
  documentScanJobs         DocumentScanJob[]
  expenseRecords           ExpenseRecord[]
  financialInsight         FinancialInsight?
  invoices                 Invoice[]
  issuedDocuments          IssuedDocument[]
  meckanoZones             MeckanoZone[]
  organizationInvites      OrganizationInvite[]
  productPriceObservations ProductPriceObservation[]
  projects                 Project[]
  projectQuotes            ProjectQuote[]
  projectBoqLines          ProjectBoqLine[]
  progressBills            ProgressBill[]
  contextComments          ContextComment[]
  workDiaries              WorkDiary[]
  paymentMilestones        PaymentMilestone[]
  projectExtras            ProjectExtra[]
  projectExpenses          ProjectExpense[]
  notebooks                Notebook[]
  quotes                   Quote[]
  tasks                    Task[]
  users                    User[]
  documentDrafts           DocumentDraft[]
  fieldCopilotSessions     FieldCopilotSession[]
  googleCalendarSettings   UserGoogleCalendarSettings[]
  googleCalendarEventLinks GoogleCalendarEventLink[]
  customAppSchemas         CustomAppSchema[]
  customAppData            CustomAppData[]
  inventoryItems           InventoryItem[]
  assets                   Asset[]
  suppliers                Supplier[]
  purchaseRequests         PurchaseRequest[]
  purchaseOrders           PurchaseOrder[]
}

/// טיוטה אוטומטית של DocumentCreatorWidget — יחידה למשתמש/ארגון/סוג מסמך
model DocumentDraft {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  /// סוג מסמך (INVOICE / RECEIPT / QUOTE …) כפי שמוגדר ב-DocType
  docType        String
  /// payload חופשי: { items, dueDate, paymentMethod, contactId, clientName, notes }
  payload        Json
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, docType], name: "draft_per_user_doctype")
  @@index([organizationId])
  @@index([userId])
}

/// אזורי דיווח מורשים למקאנו — נקודות עבודה/אתרים לחתימה
model MeckanoZone {
  id                  String       @id @default(cuid())
  name                String
  organizationId      String
  isActive            Boolean      @default(true)
  syncedToCrm         Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  address             String
  /// מזהי עובדים ממקאנו המשויכים לפרויקט (int[])
  assignedEmployeeIds Int[]        @default([])
  budgetHours         Float?
  description         String?
  endDate             DateTime?
  hourlyRate          Float?
  lat                 Float?
  lng                 Float?
  managerName         String?
  projectNotes        String?
  radius              Int          @default(150)
  startDate           DateTime?
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  linkedCrmProjects   Project[]

  @@index([organizationId])
}

/// הזמנה להצטרף לארגון קיים — אחרי הרשמה המשתמש מקבל את התפקיד שנבחר (ברירת מחדל: עובד)
model OrganizationInvite {
  id             String       @id @default(cuid())
  token          String       @unique
  email          String
  organizationId String
  role           UserRole     @default(EMPLOYEE)
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime     @default(now())
  createdByEmail String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([organizationId])
  @@index([expiresAt])
}

/// הגדרות גבייה גלובליות (מחירי מנוי / חבילות) — שורת singleton id=default
model OSBillingConfig {
  id                    String   @id @default("default")
  /// מחירי מנוי חודשי בשקלים לפי מפתח רמה, למשל { "HOUSEHOLD": 59.9 }
  tierMonthlyPricesJson Json?
  /// מזהה לקוח PayPal ציבורי (עוקף NEXT_PUBLIC אם מוגדר)
  paypalClientIdPublic  String?
  updatedAt             DateTime @updatedAt
}

/// חבילת סריקות חד־פעמית לרכישה
model ScanBundle {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  priceIls    Float
  cheapAdds   Int      @default(0)
  premiumAdds Int      @default(0)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}

/// הזמנת מנוי מטעם Executive — קישור עם טוקן לרישום
model SubscriptionInvitation {
  id               String           @id @default(cuid())
  token            String           @unique
  email            String
  subscriptionTier SubscriptionTier
  expiresAt        DateTime
  usedAt           DateTime?
  createdAt        DateTime         @default(now())
  createdByEmail   String?

  @@index([email])
  @@index([expiresAt])
}

/// פרויקט / עסק תחת ארגון — לשיוך לקוחות ומעקב
model Project {
  id               String             @id @default(cuid())
  name             String
  organizationId   String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  /// סטטוס תצוגה (פעיל / מושהה וכו')
  status           String             @default("פעיל")
  /// לקוח ראשי מ-CRM
  primaryContactId String?
  /// סנכרון אוטומטי מול Contact.projectId
  autoSyncCrm      Boolean            @default(true)
  /// תחילת תקופת עבודה / זמינות (אופציונלי)
  activeFrom       DateTime?
  /// סיום תקופה מתוכננת (אופציונלי) — לתכנון משאבים
  activeTo         DateTime?
  /// פרויקט פעיל — מופיע בברירות מחדל; כבוי = ארכיון / לא ממשיך
  isActive         Boolean            @default(true)
  /// תקציב הפרויקט
  budget           Float              @default(0)
  /// אופציונלי — קישור לאזור שטח/אתר במקאנו (אותו ארגון)
  meckanoZoneId    String?
  /// תיקיית Google Drive ייעודית לפרויקט
  driveFolderId    String?
  driveFolderName  String?
  /// ייבוא לוח זמנים (MPP/XML)
  lastScheduleImportAt DateTime?
  scheduleSourceFile   String?
  /// מדיניות סנכרון CRM: { syncDirection, onContactProjectChange }
  crmSyncPolicyJson Json?
  contacts         Contact[]
  expenseRecords   ExpenseRecord[]
  workDiaries      WorkDiary[]
  paymentMilestones PaymentMilestone[]
  projectExtras    ProjectExtra[]
  projectExpenses  ProjectExpense[]
  meckanoZone      MeckanoZone?       @relation(fields: [meckanoZoneId], references: [id])
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  primaryContact   Contact?           @relation("ProjectPrimaryContact", fields: [primaryContactId], references: [id], onDelete: SetNull)
  tasks            Task[]
  notebooks        Notebook[]
  issuedDocuments  IssuedDocument[]
  quotes           ProjectQuote[]
  boqLines         ProjectBoqLine[]
  progressBills    ProgressBill[]
  assets           Asset[]
  purchaseRequests PurchaseRequest[]
  purchaseOrders   PurchaseOrder[]

  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([meckanoZoneId])
  @@index([primaryContactId])
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  status         String       @default("TODO") // TODO, IN_PROGRESS, DONE
  priority       String       @default("MEDIUM") // LOW, MEDIUM, HIGH
  dueDate        DateTime?
  startDate      DateTime?
  endDate        DateTime?
  progress       Int          @default(0)
  /// JSON array של מזהי משימות תלויות
  dependencies   String?
  /// משימת אב (היררכיית גנט)
  parentTaskId   String?
  /// מזהה חיצוני מ-MS Project
  externalTaskId String?
  /// שורת כתב כמויות מקושרת
  linkedBoqLineId String?
  /// מקור המשימה: MANUAL (ידני/ברירת מחדל) או AI_GANTT (נוצר ע"י סוכן הגאנט)
  source         String       @default("MANUAL")
  /// נתונים מובנים לקנבן/גאנט (לקוח, תקציב, contactId וכו׳)
  metadata       Json?        @default("{}")
  projectId      String
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  googleCalendarEventLinks GoogleCalendarEventLink[]

  @@index([projectId])
  @@index([organizationId])
  @@index([status])
  @@index([linkedBoqLineId])
  /// Compound index for task-reminders cron: filters by (org, status, dueDate)
  @@index([organizationId, status, dueDate])
  /// Filters the gantt-agent replace path: deleteMany by (project, source)
  @@index([projectId, source])
}

/// יומן עבודה בשטח
model WorkDiary {
  id              String       @id @default(cuid())
  projectId       String
  organizationId  String
  date            DateTime     @default(now())
  workersCount    Int          @default(1)
  description     String       @db.Text
  progress        Int          @default(0)
  isSyncedToAI    Boolean      @default(true)
  createdByUserId String?
  weather         String?
  workHours       Float?
  materialsJson   Json?
  photosJson      Json?
  meckanoRef      String?
  linkedTaskId    String?
  linkedBoqLineId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([organizationId])
  @@index([date])
}

/// הצעת מחיר / כתב כמויות לפרויקט
model ProjectQuote {
  id             String           @id @default(cuid())
  projectId      String
  organizationId String
  version        Int              @default(1)
  title          String
  status         String           @default("draft")
  sourceFileName String?
  totalAmount    Float            @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  boqLines       ProjectBoqLine[]

  @@index([projectId])
  @@index([organizationId])
}

/// שורת כתב כמויות
model ProjectBoqLine {
  id                 String                @id @default(cuid())
  projectId          String
  organizationId     String
  quoteId            String?
  sortOrder          Int                   @default(0)
  sectionTitle       String?
  description        String                @db.Text
  unit               String?
  quantity           Float?
  unitPrice          Float?
  lineTotal          Float                 @default(0)
  isSectionSubtotal  Boolean               @default(false)
  executedQuantity   Float?
  progressCoefficient Float?
  billedAmount       Float?
  isWorkDone         Boolean               @default(false)
  source             String?               @default("MANUAL")
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  project            Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote              ProjectQuote?         @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  phaseColumns       ProjectBoqPhaseColumn[]
  billLines          ProgressBillLine[]

  @@index([projectId])
  @@index([organizationId])
  @@index([quoteId])
}

/// עמודת אבן דרך (2–5) לשורת BOQ
model ProjectBoqPhaseColumn {
  id          String         @id @default(cuid())
  boqLineId   String
  phaseIndex  Int
  coefficient Float?
  phaseAmount Float?
  boqLine     ProjectBoqLine @relation(fields: [boqLineId], references: [id], onDelete: Cascade)

  @@unique([boqLineId, phaseIndex])
}

/// חשבון חלקי (חשבון 2, 3…)
model ProgressBill {
  id                 String             @id @default(cuid())
  projectId          String
  organizationId     String
  billNumber         Int
  billDate           DateTime?
  subtotal           Float              @default(0)
  discountPercent    Float?
  vatPercent         Float?
  adjustmentsJson    Json?
  total              Float              @default(0)
  /// DRAFT | SUBMITTED | APPROVED | PAID
  status             String             @default("DRAFT")
  contractorName     String?
  /// אחוז ביצוע מדווח על ידי קבלן (0–100)
  completionPercent  Float?
  submittedAt        DateTime?
  approvedAt         DateTime?
  approvedByUserId   String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  project            Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines              ProgressBillLine[]

  @@unique([projectId, billNumber])
  @@index([organizationId])
  @@index([organizationId, status])
}

/// תגובה הקשרית על משימה / מסמך — תקשורת בתוך המערכת
model ContextComment {
  id             String       @id @default(cuid())
  organizationId String
  targetType     String
  targetId       String
  authorUserId   String
  text           String       @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author         User         @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([organizationId, targetType, targetId])
  @@index([authorUserId])
}

model ProgressBillLine {
  id            String         @id @default(cuid())
  billId        String
  boqLineId     String?
  description   String?        @db.Text
  contractQty   Float?
  unitPrice     Float?
  executedQty   Float?
  executedCoef  Float?
  lineTotal     Float          @default(0)
  bill          ProgressBill   @relation(fields: [billId], references: [id], onDelete: Cascade)
  boqLine       ProjectBoqLine? @relation(fields: [boqLineId], references: [id], onDelete: SetNull)

  @@index([billId])
  @@index([boqLineId])
}

/// Web Push subscription
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// חשבונות חלקיים / אבני דרך תשלום
model PaymentMilestone {
  id             String    @id @default(cuid())
  projectId      String
  organizationId String
  name           String
  amount         Float
  /// אחוז מסכום החוזה (0–100) כשהשדה amount הוא 0 או כשלשלב יש אחוז מפורש
  percent        Float?
  isPaid         Boolean   @default(false)
  datePaid       DateTime?
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([organizationId])
}

/// תוספות ושינויים בשטח
model ProjectExtra {
  id             String   @id @default(cuid())
  projectId      String
  organizationId String
  description    String
  cost           Float
  isApproved     Boolean  @default(false)
  createdAt      DateTime @default(now())
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([organizationId])
}

/// עלויות חודשיות מתוכננות (לא חשבוניות ERP)
model ProjectExpense {
  id             String   @id @default(cuid())
  projectId      String
  organizationId String
  month          String
  category       String
  amount         Float
  createdAt      DateTime @default(now())
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([organizationId])
  @@index([month])
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String?
  createdAt          DateTime            @default(now())
  organizationId     String?
  /// ברירת מחדל CLIENT — לא מנהל; יוצר ארגון ב־register מקבל ORG_ADMIN במפורש בקוד
  role               UserRole            @default(CLIENT)
  emailVerified      DateTime?
  image              String?
  accountStatus      AccountStatus       @default(ACTIVE)
  /// סיסמה מגובה bcrypt — התחברות מייל/סיסמה; משתמשי Google בלבד יכולים להשאיר ריק
  passwordHash       String?
  /// התחברות אחרונה (מעודכן ב־NextAuth signIn)
  lastLoginAt        DateTime?
  /// מסמכים שנוצרו לפני מועד זה לא יוצגו בהיסטוריית הסריקה של המשתמש
  scanHistoryClearedAt DateTime?
  /// פריסת Launcher אישית (quickGrid עם row/col, sidebar וכו׳)
  launcherConfigJson Json?
  /// פריסת חלונות workspace אישית (מיקום, גודל, z-index)
  workspaceLayoutJson Json?
  accounts           Account[]
  activityLogs       ActivityLog[]
  documents          Document[]
  issuedDocumentsCreated IssuedDocument[] @relation("IssuedDocumentCreatedBy")
  documentScanJobs   DocumentScanJob[]
  inAppNotifications InAppNotification[]
  pushSubscriptions  PushSubscription[]
  notebooks          Notebook[]
  sessions           Session[]
  passkeys           UserPasskey[]
  passwordResetTokens PasswordResetToken[]
  fieldCopilotSessions FieldCopilotSession[]
  googleCalendarSettings UserGoogleCalendarSettings[]
  googleCalendarEventLinks GoogleCalendarEventLink[]
  assignedAssets         Asset[]                 @relation("AssetAssignedUser")
  contextComments        ContextComment[]
  organization       Organization?       @relation(fields: [organizationId], references: [id])

  @@index([lastLoginAt])
}

/// מפתחות Passkey (WebAuthn) לכניסה ביומטרית
model UserPasskey {
  id           String   @id @default(cuid())
  userId       String
  credentialId String   @unique
  publicKey    Bytes
  counter      BigInt   @default(0)
  deviceName   String?
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// איפוס סיסמה — טוקן חד-פעמי במייל
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// הודעות בתוך המערכת (פעמון בדשבורד)
model InAppNotification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  read      Boolean  @default(false)
  /// סוג ניווט: project | erp | aiScanner | expense | general
  linkType  String?
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

/// מחברת NotebookLM — מקורות, שיחה וסקירה קולית
model Notebook {
  id             String                  @id @default(cuid())
  userId         String
  organizationId String?
  projectId      String?
  title          String
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization?           @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  project        Project?                @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sources        NotebookSource[]
  messages       NotebookMessage[]
  audioOverview  NotebookAudioOverview?

  @@index([userId, updatedAt])
  @@index([organizationId])
  @@index([projectId])
}

model NotebookSource {
  id         String   @id @default(cuid())
  notebookId String
  name       String
  content    String   @db.Text
  mimeType   String   @default("application/pdf")
  sortOrder  Int      @default(0)
  notebook   Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@index([notebookId, sortOrder])
}

model NotebookMessage {
  id         String   @id @default(cuid())
  notebookId String
  role       String
  content    String   @db.Text
  createdAt  DateTime @default(now())
  notebook   Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@index([notebookId, createdAt])
}

model NotebookAudioOverview {
  id         String   @id @default(cuid())
  notebookId String   @unique
  scriptText String   @db.Text
  createdAt  DateTime @default(now())
  notebook   Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
}

model CloudIntegration {
  id              String        @id @default(cuid())
  organizationId  String
  provider        CloudProvider
  displayName     String?
  accessToken     String?
  refreshToken    String?
  tokenExpiresAt  DateTime?
  autoScan        Boolean       @default(false)
  backupExports   Boolean       @default(false)
  folderPath      String?
  /// תיקיית עבודה ב-Google Drive (מזהה)
  driveFolderId   String?
  /// שם תיקיית ברירת מחדל (למשל BSD-YBM)
  driveFolderName String?       @default("BSD-YBM")
  /// סנכרון דו-כיווני אוטומטי
  driveSyncEnabled Boolean      @default(true)
  /// Changes API page token
  driveSyncCursor String?
  lastSyncAt      DateTime?
  /// פענוח אוטומטי לקבצים חדשים אחרי סנכרון
  driveAutoDecodeOnSync    Boolean @default(false)
  /// שמירה אוטומטית ל-ERP/CRM אחרי פענוח מוצלח
  driveAutoSaveAfterDecode Boolean @default(false)
  /// פתיחת פאנל אישור לפני שמירה (כשאין זיהוי לקוח בטוח)
  driveAskBeforeSave       Boolean @default(true)
  /// מזהי תת-תיקיות מאגר ידע תחת תיקיית העבודה { rootId, ingestId, parsedId, issuedId }
  knowledgeVaultFoldersJson Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@index([organizationId])
}

/// מראה מטא-דאטה של קבצים בתיקיית העבודה ב-Drive (לסנכרון דו-כיווני)
model DriveSyncEntry {
  id                 String             @id @default(cuid())
  organizationId     String
  driveFileId        String
  parentDriveId      String?
  name               String
  mimeType           String
  md5Checksum        String?
  modifiedTime       DateTime?
  webViewLink        String?
  trashed            Boolean            @default(false)
  decodeStatus       DriveDecodeStatus?
  decodeError        String?
  linkedDocumentId   String?
  lastDecodedAt      DateTime?
  detectedClientName String?
  detectedDocType    String?
  /// נתיב במאגר ידע (Ingest / Parsed / Issued / Archive)
  vaultPath          KnowledgeVaultPath?
  /// תקציר פענוח (טקסט, שדות מפתח) — לא הקובץ עצמו
  parsedSummary      Json?
  /// ווידג'ט שהנפיק את הקובץ
  issuedByWidget     String?
  /// ווידג'ט שביצע ingest
  sourceWidgetId     String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  knowledgeChunks    KnowledgeVaultChunk[]

  @@unique([organizationId, driveFileId])
  @@index([organizationId, parentDriveId])
  @@index([organizationId, trashed])
  @@index([organizationId, decodeStatus])
  @@index([organizationId, vaultPath])
}

/// קטעי טקסט + embedding לחיפוש RAG במאגר ידע (Gemini + cosine ב-JS)
model KnowledgeVaultChunk {
  id             String         @id @default(cuid())
  organizationId String
  driveEntryId   String
  chunkIndex     Int
  content        String         @db.Text
  embedding      Json?
  textHash       String
  updatedAt      DateTime       @updatedAt @default(now())
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  driveEntry     DriveSyncEntry @relation(fields: [driveEntryId], references: [id], onDelete: Cascade)

  @@unique([driveEntryId, chunkIndex])
  @@index([organizationId])
}

/// OAuth / NextAuth — נדרש עבור PrismaAdapter (התחברות Google)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Contact {
  id              String           @id @default(cuid())
  name            String
  email           String?
  status          String           @default("LEAD")
  organizationId  String
  createdAt       DateTime         @default(now())
  projectId       String?
  notes           String?
  phone           String?
  value           Float?
  /// תגיות לפילוח דינמי (CRM)
  tags            String[]         @default([])
  organization    Organization     @relation(fields: [organizationId], references: [id])
  project         Project?         @relation(fields: [projectId], references: [id])
  primaryForProjects Project[]   @relation("ProjectPrimaryContact")
  expenseRecords  ExpenseRecord[]
  issuedDocuments IssuedDocument[]
  quotes          Quote[]
  searchEmbedding ContactSearchEmbedding?

  @@index([organizationId])
  @@index([projectId])
  @@index([status, value])
  @@index([createdAt])
}

/// וקטור חיפוש סמנטי ל-CRM (Gemini embeddings, cosine ב-JS)
model ContactSearchEmbedding {
  id             String       @id @default(cuid())
  organizationId String
  contactId      String       @unique
  textHash       String
  embedding      Json
  updatedAt      DateTime     @updatedAt
  contact        Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

/// תובנות AI יומיות (מצב חיסכון) – רשומה אחת לכל ארגון
model FinancialInsight {
  id             String       @id @default(cuid())
  organizationId String       @unique
  content        String
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

/// מסמכי מס שהארגון מנפיק (חשבונית / קבלה וכו׳) — לא כמו מודל Document של קבצים סרוקים ב־ERP
model IssuedDocument {
  id             String       @id @default(cuid())
  type           DocType
  /// מספר מסמך רץ בתוך הארגון (לפי סוג)
  number         Int
  date           DateTime     @default(now())
  dueDate        DateTime?
  clientName     String
  /// סכום לפני מע״מ
  amount         Float
  vat            Float
  total          Float
  status         DocStatus    @default(PENDING)
  /// מספר הקצאה מרשות המסים (ITA) — חובה מעל 25,000 ₪
  itaAllocationNumber String?
  lastReminderAt      DateTime?
  reminderCount       Int          @default(0)
  /// פריטים: [{ desc, qty, price }, ...]
  items          Json
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  /// קישור ל-CRM — לקוח שממנו הגיעה עסקה (אופציונלי, לסנכרון CRM↔ERP)
  contactId      String?
  contact        Contact?     @relation(fields: [contactId], references: [id])
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// מי הפיק את המסמך (לסינון «שותפו איתי»)
  createdByUserId String?
  createdByUser   User?        @relation("IssuedDocumentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  purchaseOrders PurchaseOrder[]
  deletedAt       DateTime?

  @@unique([organizationId, type, number])
  @@index([organizationId])
  @@index([contactId])
  @@index([projectId])
  @@index([organizationId, deletedAt])
  /// For collection-reminders cron: filters pending overdue documents across all orgs
  @@index([status, dueDate])
}

/// הוצאה / חשבונית ספק — משרד, פרויקט או לקוח; ניתן לקליטה מסריקה ו-AI
model ExpenseRecord {
  id               String              @id @default(cuid())
  organizationId   String
  vendorName       String
  invoiceNumber    String?
  expenseDate      DateTime            @default(now())
  description      String?
  amountNet        Float
  vat              Float               @default(0)
  total            Float
  allocation       ExpenseAllocation   @default(OFFICE)
  projectId        String?
  contactId        String?
  status           ExpenseRecordStatus @default(POSTED)
  sourceDocumentId String?
  aiExtractedJson  Json?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  contact          Contact?            @relation(fields: [contactId], references: [id])
  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project          Project?            @relation(fields: [projectId], references: [id])
  sourceDocument   Document?           @relation(fields: [sourceDocumentId], references: [id])

  @@index([organizationId, expenseDate])
  @@index([organizationId, allocation])
  @@index([projectId])
  @@index([contactId])
}

/// חשבונית / תשלום — עדכון סטטוס מ־PayPlus (או ספקים אחרים) דרך webhook
model Invoice {
  id                   String       @id @default(cuid())
  organizationId       String
  status               String       @default("PENDING")
  amount               Float?
  currency             String       @default("ILS")
  /// מזהה עסקה ב־PayPlus (uid) לאחר אישור
  payplusTransactionId String?      @unique
  paidAt               DateTime?
  lastWebhookPayload   Json?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  customerEmail        String?
  customerName         String?
  /// תיאור להצגה בדשבורד / במייל
  description          String?
  /// מספר חשבונית להצגה (לא חובה = מזהה קצר)
  invoiceNumber        String?
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status, createdAt])
  @@index([customerEmail])
}

/// הצעת מחיר לחתימה דיגיטלית
model Quote {
  id              String       @id @default(cuid())
  token           String       @unique
  amount          Float
  signatureBase64 String?
  status          String       @default("PENDING")
  contactId       String
  organizationId  String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  contact         Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([contactId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

model DocumentScanJob {
  id             String                @id @default(uuid())
  status         DocumentScanJobStatus @default(PENDING)
  /// JSON או base64/URL — מטא־דאטה + תוכן (ראו קוד ה־API)
  fileData       String
  result         Json?
  error          String?
  userId         String
  organizationId String
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
}

model Document {
  id                       String                    @id @default(cuid())
  fileName                 String
  type                     String
  status                   String                    @default("PROCESSED")
  aiData                   Json?
  /// Google Drive file ID of the original scanned document (null if not archived or Drive not linked)
  fileDriveId              String?
  /// Direct browser URL to view the original file in Google Drive
  fileDriveWebViewLink     String?
  userId                   String
  organizationId           String
  createdAt                DateTime                  @default(now())
  deletedAt                DateTime?
  organization             Organization              @relation(fields: [organizationId], references: [id])
  user                     User                      @relation(fields: [userId], references: [id])
  lineItems                DocumentLineItem[]
  expenseRecords           ExpenseRecord[]
  productPriceObservations ProductPriceObservation[]

  @@index([organizationId, createdAt])
  @@index([organizationId, deletedAt])
  @@index([fileDriveId])
}

/// תוצאת סריקת AI לפי גיבוב קובץ — חיסכון במכסה ובעלות API
model DocumentScanCache {
  id             String       @id @default(cuid())
  organizationId String
  contentSha256  String
  providerUsed   String
  locale         String
  schemaVersion  Int          @default(2)
  resultJson     Json
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, contentSha256, providerUsed, locale, schemaVersion])
  @@index([organizationId])
}

/// שורות מוצר/שירות מחשבוניות, קבלות והצעות — ללוח ספקים והשוואת מחירים
model DocumentLineItem {
  id                String       @id @default(cuid())
  documentId        String
  organizationId    String
  supplierName      String?
  description       String
  normalizedKey     String
  quantity          Float?
  unitPrice         Float?
  lineTotal         Float?
  currency          String       @default("ILS")
  sku               String?
  createdAt         DateTime     @default(now())
  /// true כשה-AI זיהה שורת חומר/שירות ללא מחיר תקף — להשלמה ידנית בלוח ERP
  priceAlertPending Boolean      @default(false)
  document          Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, normalizedKey])
  @@index([documentId])
  @@index([organizationId, priceAlertPending])
}

/// צילום מחיר היסטורי לשורה — לאיתור ספק זול יותר
model ProductPriceObservation {
  id             String       @id @default(cuid())
  organizationId String
  documentId     String?
  normalizedKey  String
  description    String
  supplierName   String?
  unitPrice      Float
  currency       String       @default("ILS")
  observedAt     DateTime     @default(now())
  document       Document?    @relation(fields: [documentId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, normalizedKey, observedAt])
}

model ActivityLog {
  id             String       @id @default(cuid())
  action         String
  details        String?
  userId         String
  organizationId String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([userId, action])
}

model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

/// חוקי אוטומציה — תשתית לעורך ה-workflow (מסך /app/settings/automations)
model Automation {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  description    String?
  enabled        Boolean         @default(true)
  /// לדוגמה: STATUS_CHANGE | CONTACT_CREATED | INVOICE_SENT
  triggerType    String
  triggerValue   String?
  /// לדוגמה: SEND_EMAIL | WEBHOOK | ADD_NOTE
  actionType     String
  actionConfig   Json            @default("{}")
  runCount       Int             @default(0)
  lastRunAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  runs           AutomationRun[]

  @@index([organizationId, enabled])
  @@index([organizationId, triggerType])
}

model AutomationRun {
  id           String     @id @default(cuid())
  automationId String
  entityId     String?
  entityType   String?
  status       String     @default("OK")
  errorMessage String?
  createdAt    DateTime   @default(now())
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId, createdAt])
}

/// הגדרות מפתח־ערך גלובליות לשרת (אופציונלי)
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  group     String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// תור לאיגוד מיילי התראה — נשלחים כמייל סיכום אחד לנמען
model EmailDigestItem {
  id        String   @id @default(cuid())
  recipient String
  category  String
  title     String
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([recipient, category, createdAt])
}

enum CustomerType {
  HOME
  FREELANCER
  COMPANY
  ENTERPRISE
}

/// סוג ישות עסקית למע״מ (עוסק פטור / מורשה / חברה בע״מ) — נפרד מ־CustomerType
enum CompanyType {
  EXEMPT_DEALER
  LICENSED_DEALER
  LTD_COMPANY
}

/// סוג מסמך מס שהונפק על ידי הארגון (לא מסמכי סריקה ב־Document)
enum DocType {
  QUOTE
  TRANSACTION_INVOICE
  INVOICE
  INVOICE_RECEIPT
  RECEIPT
  CREDIT_NOTE
  PURCHASE_ORDER
}

enum DocStatus {
  PENDING
  PAID
  CANCELLED
}

/// שיוך הוצאה — משרד כללי, פרויקט או לקוח
enum ExpenseAllocation {
  OFFICE
  PROJECT
  CLIENT
}

enum ExpenseRecordStatus {
  DRAFT
  POSTED
}

/// תפקידים במערכת — אין כאן USER/ADMIN גנרי:
/// CLIENT = משתמש קצה (ברירת מחדל), EMPLOYEE/PROJECT_MGR = צוות,
/// ORG_ADMIN = מנהל ארגון, SUPER_ADMIN = מנהל פלטפורמה בלבד.
enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  PROJECT_MGR
  EMPLOYEE
  CLIENT
}

enum AccountStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
}

/// רמות מנוי — מכסות סריקה (זולה = Gemini, פרימיום = OpenAI/Anthropic)
enum SubscriptionTier {
  FREE
  HOUSEHOLD
  DEALER
  COMPANY
  CORPORATE
}

/// ספקי ענן לגיבוי / סריקה אוטונומית (הרשאות OAuth יתווספו בהמשך)
enum CloudProvider {
  GOOGLE_DRIVE
  ONEDRIVE
  DROPBOX
  ICLOUD
  S3_COMPATIBLE
}

/// סריקת מסמך אסינכרונית — תור רקע מול Vercel timeout / מגבלות Google
enum DriveDecodeStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  NEEDS_REVIEW
}

enum KnowledgeVaultPath {
  INGEST
  PARSED
  ISSUED
  ARCHIVE
}

enum DocumentScanJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model AICorrection {
  id               String       @id @default(cuid())
  organizationId   String
  documentId       String?
  originalAiData   Json
  correctedData    Json
  correctionSource String       @default("USER_MANUAL")
  createdAt        DateTime     @default(now())
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdAt])
}

/// הגדרות פלטפורמה גלובליות (רשומה יחידה id=default)
model PlatformSettings {
  id         String   @id @default("default")
  configJson Json
  updatedAt  DateTime @updatedAt
}

enum FieldCopilotSessionStatus {
  DRAFT
  ANALYZING
  READY
  HANDED_OFF
  ARCHIVED
}

/// סשן קופיילוט שטח — לכידה, ניתוח והפקת הצעה
model FieldCopilotSession {
  id                String                    @id @default(cuid())
  organizationId    String
  userId            String
  contactId         String?
  projectId         String?
  contactName       String?
  projectName       String?
  constructionTrade String?
  transcript        String?                   @db.Text
  userNotes         String?                   @db.Text
  videoAssetId      String?
  analysisJson      Json?
  scopeSummary      String?                   @db.Text
  assumptionsJson   Json                      @default("[]")
  status            FieldCopilotSessionStatus @default(DRAFT)
  handedOffAt       DateTime?
  issuedDocumentId  String?
  quoteId           String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  organization      Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user              User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets            FieldCopilotAsset[]

  @@index([organizationId, userId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

enum GoogleCalendarSyncMode {
  OFF
  READ_ONLY
  BIDIRECTIONAL
}

enum GoogleCalendarEntityType {
  TASK
  STANDALONE
}

enum GoogleCalendarSyncSource {
  GOOGLE
  LOCAL
}

/// הגדרות יומן Google למשתמש — סנכרון רק אחרי אישור מפורש (opt-in)
model UserGoogleCalendarSettings {
  id                    String                 @id @default(cuid())
  userId                String
  organizationId        String
  syncMode              GoogleCalendarSyncMode @default(OFF)
  enabled               Boolean                @default(false)
  consentAt             DateTime?
  consentVersion        String?
  calendarId            String?
  calendarSummary       String?
  calendarColor         String?
  syncToken             String?
  lastSyncAt            DateTime?
  lastSyncError         String?
  reminderMinutesBefore Int                    @default(15)
  pushEnabled           Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([enabled, syncMode])
}

/// מראה מקומית לאירועי Google Calendar (סנכרון דו-כיווני)
model GoogleCalendarEventLink {
  id               String                   @id @default(cuid())
  userId           String
  organizationId   String
  googleCalendarId String
  googleEventId    String
  googleEtag       String?
  entityType       GoogleCalendarEntityType @default(STANDALONE)
  taskId           String?
  summary          String
  startAt          DateTime
  endAt            DateTime
  allDay           Boolean                  @default(false)
  htmlLink         String?
  lastSyncedFrom   GoogleCalendarSyncSource @default(GOOGLE)
  pushNotifiedAt   DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task             Task?                    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@unique([userId, googleCalendarId, googleEventId])
  @@index([userId, startAt])
  @@index([organizationId, startAt])
  @@index([taskId])
  @@index([pushNotifiedAt, startAt])
}

/// נכסי לכידה (תמונה / keyframe) — base64 ב-DB לסביבת serverless
model FieldCopilotAsset {
  id                 String              @id @default(cuid())
  sessionId          String
  organizationId     String
  mimeType           String
  kind               String
  dataBase64         String              @db.Text
  driveFileId        String?
  driveWebViewLink   String?
  driveFolderId      String?
  driveArchiveStatus String?
  driveError         String?
  createdAt          DateTime            @default(now())
  session            FieldCopilotSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([organizationId])
}

/// סכמת UI שנוצרה ע"י AI App Builder — מבנה טופס/טבלה בלבד (לא נתוני משתמש)
model CustomAppSchema {
  id             String           @id @default(cuid())
  organizationId String?
  name           String
  description    String?
  uiSchema       Json
  jsxCode        String?
  isGlobal       Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dataRows       CustomAppData[]

  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@index([isGlobal])
}

/// נתונים שהוזנו דרך טופס דינמי — מופרד מסכמת ה-UI
model CustomAppData {
  id             String          @id @default(cuid())
  organizationId String
  schemaId       String
  data           Json
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  schema         CustomAppSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([schemaId])
  @@index([organizationId, schemaId, createdAt])
}

/// רעיון אפליקציה שמנוי בחר לשתף עם הפלטפורמה — מושב ממידע אישי, מושב מנתוני ארגון
model AppIdeaSubmission {
  id          String   @id @default(cuid())
  uiSchema    Json
  appName     String
  appType     String
  status      String   @default("pending") // pending | approved | rejected
  orgIndustry String?
  createdAt   DateTime @default(now())

  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

// ==========================================
// Logistics, Inventory & Assets
// ==========================================

enum AssetStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  LOST
}

model InventoryItem {
  id             String       @id @default(cuid())
  name           String
  sku            String?
  category       String       @default("general")
  quantity       Float        @default(0)
  minQuantity    Float        @default(0)
  unit           String       @default("units")
  location       String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchaseRequests PurchaseRequest[]
  purchaseOrderLines PurchaseOrderLine[]

  @@index([organizationId])
  @@index([organizationId, category])
}

model Asset {
  id              String             @id @default(cuid())
  name            String
  serialNumber    String?
  type            String             @default("tool")
  status          AssetStatus        @default(AVAILABLE)
  currentUserId   String?
  projectId       String?
  organizationId  String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  currentUser     User?              @relation("AssetAssignedUser", fields: [currentUserId], references: [id], onDelete: SetNull)
  project         Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  checkoutLogs    AssetCheckoutLog[]

  @@unique([organizationId, serialNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([projectId])
  @@index([currentUserId])
}

model AssetCheckoutLog {
  id             String   @id @default(cuid())
  assetId        String
  organizationId String
  userId         String?
  projectId      String?
  action         String
  notes          String?
  createdAt      DateTime @default(now())
  asset          Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, createdAt])
  @@index([organizationId])
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  contactPerson  String?
  email          String?
  phone          String?
  taxId          String?
  paymentTerms   String?
  organizationId String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@index([organizationId])
}

model PurchaseRequest {
  id              String         @id @default(cuid())
  title           String
  status          String         @default("PENDING")
  source          String         @default("LOW_STOCK")
  notes           String?
  quantityNeeded  Float          @default(0)
  projectId       String?
  inventoryItemId String?
  organizationId  String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([projectId])
  @@index([inventoryItemId])
}

model PurchaseOrder {
  id             String              @id @default(cuid())
  orderNumber    String
  status         String              @default("DRAFT")
  totalAmount    Float               @default(0)
  currency       String              @default("ILS")
  expectedDate   DateTime?
  notes          String?
  supplierId     String
  projectId      String?
  issuedDocumentId String?
  organizationId String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  supplier       Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  project        Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  issuedDocument IssuedDocument?     @relation(fields: [issuedDocumentId], references: [id], onDelete: SetNull)
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lineItems      PurchaseOrderLine[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId])
  @@index([supplierId])
  @@index([projectId])
  @@index([issuedDocumentId])
}

model PurchaseOrderLine {
  id              String         @id @default(cuid())
  description     String
  quantity        Float
  unitPrice       Float
  totalPrice      Float
  receivedQty     Float          @default(0)
  inventoryItemId String?
  purchaseOrderId String
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId])
  @@index([inventoryItemId])
}
