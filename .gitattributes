# Consistent line endings
* text=auto eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binaries — no diff, no merge
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.gif binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.zip binary
*.tar.gz binary
*.db binary
