# =============================================================================
# BSD-YBM — דוגמה למשתני סביבה
# העתיקו ל־`.env.local` (או `.env`), מלאו ערכים אמיתיים, ואל תעלו קבצי סודות ל-Git.
# =============================================================================

# --- Postgres (חובה ל־Prisma / build מקומי) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# אופציונלי אם משתמשים ב-pooler של Neon ומיגרציות נכשלות:
# DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- NextAuth (מומלץ לפיתוח/פרודקשן) ---
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000
# AUTH_URL=http://localhost:3000

# --- Google Gemini (חובה ל־AI במערכת, כולל ווידג'ט NotebookLM ב-OS) ---
# מפתח מ־Google AI Studio / Vertex — מספיק אחד מהשניים:
GOOGLE_GENERATIVE_AI_API_KEY="your-api-key-here"
# GEMINI_API_KEY="alternative-env-name-same-purpose"

# דגם כללי לפרויקט (אופציונלי; ברירת מחדל ב־lib/gemini-model.ts)
# GEMINI_MODEL=gemini-2.5-flash
# GOOGLE_GENERATIVE_AI_MODEL=gemini-2.5-flash

# דגם לצ'אט NotebookLM ב-OS (`/api/notebooklm/chat`). ברירת מחדל בקוד: gemini-1.5-flash
# GEMINI_NOTEBOOKLM_MODEL=gemini-2.5-flash

# דגם למחברת ERP (נתיבים אחרים; לא חובה לווידג'ט OS)
# GEMINI_NOTEBOOK_MODEL=gemini-2.5-flash-lite
