# =============================================================================
# BSD-YBM — דוגמה למשתני סביבה
# העתיקו ל־`.env.local` (או `.env`), מלאו ערכים אמיתיים, ואל תעלו קבצי סודות ל-Git.
# =============================================================================

# --- Postgres (חובה ל־Prisma / build מקומי) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# אופציונלי אם משתמשים ב-pooler של Neon ומיגרציות נכשלות:
# DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- משפטי / GDPR (פרודקשן) ---
# NEXT_PUBLIC_LEGAL_ENTITY_NAME=שם-מפעיל-או-חברה
# NEXT_PUBLIC_LEGAL_ENTITY_ID=ח.פ.-או-עוסק-מורשה (אופציונלי)
# NEXT_PUBLIC_LEGAL_REGISTERED_ADDRESS=כתובת-רשומה-אמיתית-שלכם (חובה — אל תמציאו; ראו docs/legal-env-setup-he.md)
# NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=yb@bsd-ybm.co.il
# NEXT_PUBLIC_EU_REPRESENTATIVE=לא-חל (או פרטי נציג באיחוד אם חל)
# רשתות חברתיות ל-JSON-LD sameAs (מופרד בפסיקים)
# NEXT_PUBLIC_SAME_AS=https://www.linkedin.com/company/example

# --- אימות Search Console / מנועי חיפוש (לאחר deploy) ---
# SITE_VERIFICATION_GOOGLE=ערך-מתוך-Google-Search-Console
# GOOGLE_SITE_VERIFICATION=אותו-ערך-חלופי
# SITE_VERIFICATION_BING=
# SITE_VERIFICATION_YANDEX=

# --- NextAuth / כתובות אתר (חובה להתאים בין פיתוח לפרודקשן) ---
# NEXTAUTH_SECRET=מחרוזת-אקראית-ארוכה
#
# פיתוח מקומי:
# NEXTAUTH_URL=http://localhost:3000
# AUTH_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
#
# פרודקשן — דומיין קנוני אחד (www). ב-Vercel: npm run vercel:env:push:auth
# NEXTAUTH_URL=https://www.bsd-ybm.co.il
# AUTH_URL=https://www.bsd-ybm.co.il
# NEXT_PUBLIC_SITE_URL=https://www.bsd-ybm.co.il
#
# Google OAuth (אל תעלו ל-Git — הגדירו ב-Vercel / .env.local בלבד):
# GOOGLE_CLIENT_ID=          # Client B — Drive + Contacts
# GOOGLE_CLIENT_SECRET=
# GOOGLE_SIGNIN_CLIENT_ID=   # אופציונלי — Client A — כניסה בלבד (openid, email, profile)
# GOOGLE_SIGNIN_CLIENT_SECRET=
#
# Redirect URIs (Client A — sign-in):
#   .../api/auth/callback/google
# Redirect URIs (Client B — integrations):
#   .../api/auth/google-reconnect/callback
#   .../api/integrations/google/contacts/callback
# JavaScript origins: http://localhost:3000 , https://www.bsd-ybm.co.il
# מדריך: docs/GOOGLE-OAUTH.md | runbook: docs/google-oauth-verification-runbook-he.md

# --- PostHog (אנליטיקה) ---
# אינטגרציית Vercel Marketplace מוסיפה: NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN + HOST
# הקוד תומך גם ב-NEXT_PUBLIC_POSTHOG_KEY (ידני)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# התקנה: npm run vercel:integration:posthog  (דורש אישור תנאים בדפדפן)

# --- E2E / seed לבדיקות Playwright ---
# E2E_EMAIL=owner@bsd-demo.test
# E2E_PASSWORD=Demo!2026

# --- Google Gemini (חובה ל־AI במערכת, כולל ווידג'ט NotebookLM ב-OS) ---
# מפתח מ־Google AI Studio / Vertex — מספיק אחד מהשניים:
GOOGLE_GENERATIVE_AI_API_KEY="your-api-key-here"
# מודל לצ'אט הסוכן (/api/chat) — אופציונלי (ברירת מחדל: gemini-3.5-flash)
# GEMINI_AGENT_MODEL=gemini-3.5-flash
# GEMINI_API_KEY="alternative-env-name-same-purpose"

# דגם כללי לפרויקט (אופציונלי; ברירת מחדל: gemini-3.5-flash)
# GEMINI_MODEL=gemini-3.5-flash
# GOOGLE_GENERATIVE_AI_MODEL=gemini-3.5-flash

# דגם לצ'אט NotebookLM (`/api/notebooklm/chat`). ברירת מחדל: gemini-3.5-flash
# GEMINI_NOTEBOOKLM_MODEL=gemini-3.5-flash

# גרמושקה / מרכז פרויקט — ניתן לדרוס; BLUEPRINT_USE_FLASH_ONLY=true לחיסכון בעלות
# GEMINI_BLUEPRINT_MODEL=gemini-3.5-flash
# BLUEPRINT_USE_FLASH_ONLY=false
# GEMINI_THINKING_LEVEL=medium

# עוזר ניהול (אופציונלי)
# GEMINI_ADMIN_ASSISTANT_MODEL=gemini-3.5-flash

# Live (עוזר קולי): gemini-2.5-flash-native-audio-latest — ראה lib/gemini-model.ts
# GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-latest

# דגם למחברת ERP (נתיבים אחרים; לא חובה לווידג'ט OS)
# GEMINI_NOTEBOOK_MODEL=gemini-2.5-flash-lite

# --- Web Push (יומן עבודות / פרויקט) ---
# צורו מפתחות: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:yb@bsd-ybm.co.il
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=אותו-ערך-כמו-VAPID_PUBLIC_KEY

# --- Cron / תורים / דיבוג (פרודקשן) ---
# CRON_SECRET=סוד-ל-cron-financial-insights
# ANALYZE_QUEUE_SECRET=סוד-ל-analyze-queue-process
# ENABLE_DEBUG_SESSION=true
# DISABLE_AI_FALLBACK=1   # P1 DR — כיבוי fallback AI; סריקה/צ'אט מחזירים 503 ידידותי

# --- מס הכנסה — מספר הקצאה (ITA) ---
# ITA_PRODUCTION_KEY=מפתח-production-ממשרד-המסים
# ALLOW_ITA_MOCK=true       # mock רק local/E2E — אסור בפרודקשן
# ללא מפתח: hard-fail מעל סף ההקצאה (אין mock בפרוד)

# --- OpenAI (סורק + fallback) ---
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini          # אופציונלי — דגם לצ'אט
# OPENAI_VISION_MODEL=gpt-4o             # אופציונלי — דגם לראייה ממוחשבת

# --- Anthropic (Claude — fallback) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest  # אופציונלי

# --- Mistral / Pixtral (מנוע סריקה 4) ---
# MISTRAL_API_KEY=                        # מ-console.mistral.ai
# MISTRAL_MODEL=mistral-small-latest      # אופציונלי — דגם לצ'אט
# MISTRAL_VISION_MODEL=pixtral-large-latest  # אופציונלי — דגם לסריקת תמונות/PDF

# --- Groq (מהיר — fallback) ---
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile     # אופציונלי

# --- Google Document AI (מנוע OCR מתקדם — אופציונלי) ---
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}  # Service Account JSON ב-base64 או raw
# GOOGLE_DOCUMENT_AI_PROJECT_ID=my-gcp-project
# GOOGLE_DOCUMENT_AI_LOCATION=eu                # us או eu
# GOOGLE_DOCUMENT_AI_PROCESSOR_ID=              # Processor ID כללי (אם אין חלוקה לפי סוג)
# חלוקה לפי סוג מסמך (מומלץ על פני PROCESSOR_ID כללי):
# GOOGLE_DOCUMENT_AI_INVOICE_PROCESSOR_ID=
# GOOGLE_DOCUMENT_AI_EXPENSE_PROCESSOR_ID=
# GOOGLE_DOCUMENT_AI_FORM_PROCESSOR_ID=
# GOOGLE_DOCUMENT_AI_OCR_PROCESSOR_ID=

# --- Meckano (דוחות נוכחות עובדים) ---
# MECKANO_API_KEY=                        # מ-Meckano → הגדרות → API

# --- דואר אלקטרוני (חובה לשליחת מיילים אמיתית) ---
# שולח ברירת מחדל: BSD-YBM <yb@bsd-ybm.co.il> (lib/mail-config.ts)
# נתיבים: הרשמה, אימות מחדש, הזמנות, גבייה, חשבוניות, מייל בדיקה (/api/admin/test-email)
# בדיקה מקומית: node scripts/test-email.mjs your@email.com
# דחיפה ל-Vercel: npm run vercel:env:push:mail
#
# אפשרות 1 — Resend (מומלץ; לאמת דומיין bsd-ybm.co.il ב-Resend):
# RESEND_API_KEY=re_xxxxxxxx
#
# אפשרות 2 — SMTP (למשל תיבת yb@bsd-ybm.co.il):
# SMTP_HOST=mail.bsd-ybm.co.il
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=yb@bsd-ybm.co.il
# SMTP_PASS=סיסמת-תיבה
# MAIL_FROM=yb@bsd-ybm.co.il
# MAIL_REPLY_TO=yb@bsd-ybm.co.il

# --- PayPal (אופציונלי — תשלומים) ---
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_ENV=sandbox
# ערכים תקינים: sandbox | production (גם live / prod מתורגמים ל-production)
# PAYPAL_WEBHOOK_ID=                      # לאימות webhooks
# OS_PAYPAL_MERCHANT_EMAIL=              # לכפתור PayPal.me ב-OS
# OS_PAYPAL_ME_SLUG=                     # שם המשתמש ב-PayPal.me (אחרי paypal.me/)

# --- PayPlus (תשלומים ישראליים) ---
# PAYPLUS_API_KEY=                        # מ-PayPlus Dashboard
# PAYPLUS_SECRET_KEY=                     # מ-PayPlus Dashboard
# PAYPLUS_PAYMENT_PAGE_UID=              # UID של דף התשלום ב-PayPlus

# --- סופר-אדמין פלטפורמה (מופרד בפסיק; ברירת מחדל כולל yb@bsd-ybm.co.il) ---
# OS_ADMIN_EMAILS=yb@bsd-ybm.co.il,sysybu@gmail.com

# --- תת-דומיין / דומיין מנוי (tenantPublicDomain ב-DB) ---
# TENANT_OS_HOSTS=bsd-ybm.co.il,www.bsd-ybm.co.il
# TENANT_FALLBACK_REDIRECT=https://www.bsd-ybm.co.il
