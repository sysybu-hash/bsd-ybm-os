# =============================================================================
# BSD-YBM — דוגמה למשתני סביבה
# העתיקו ל־`.env.local` (או `.env`), מלאו ערכים אמיתיים, ואל תעלו קבצי סודות ל-Git.
# =============================================================================

# --- Postgres (חובה ל־Prisma / build מקומי) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# אופציונלי אם משתמשים ב-pooler של Neon ומיגרציות נכשלות:
# DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- משפטי / GDPR (פרודקשן) ---
# NEXT_PUBLIC_LEGAL_ENTITY_NAME=
# NEXT_PUBLIC_LEGAL_ENTITY_ID=
# NEXT_PUBLIC_LEGAL_REGISTERED_ADDRESS=
# NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=
# NEXT_PUBLIC_EU_REPRESENTATIVE=
# רשתות חברתיות ל-JSON-LD sameAs (מופרד בפסיקים)
# NEXT_PUBLIC_SAME_AS=https://www.linkedin.com/company/example

# --- אימות Search Console / מנועי חיפוש (לאחר deploy) ---
# SITE_VERIFICATION_GOOGLE=ערך-מתוך-Google-Search-Console
# GOOGLE_SITE_VERIFICATION=אותו-ערך-חלופי
# SITE_VERIFICATION_BING=
# SITE_VERIFICATION_YANDEX=

# --- NextAuth (מומלץ לפיתוח/פרודקשן) ---
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000
# AUTH_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
#
# פרודקשן (Vercel — נדחף אוטומטית ע״י npm run vercel:env:push:auth):
# NEXTAUTH_URL=https://bsd-ybm.co.il
# AUTH_URL=https://bsd-ybm.co.il
# NEXT_PUBLIC_SITE_URL=https://bsd-ybm.co.il
#
# Google Cloud → OAuth Client → Authorized redirect URIs (חובה להתאים ל-NEXTAUTH_URL):
#   http://localhost:3000/api/auth/callback/google
#   https://bsd-ybm.co.il/api/auth/callback/google
#   https://www.bsd-ybm.co.il/api/auth/callback/google
#   https://bsd-ybm-os.vercel.app/api/auth/callback/google
# JavaScript origins: אותן כתובות בלי /api/auth/...

# --- Google Gemini (חובה ל־AI במערכת, כולל ווידג'ט NotebookLM ב-OS) ---
# מפתח מ־Google AI Studio / Vertex — מספיק אחד מהשניים:
GOOGLE_GENERATIVE_AI_API_KEY="your-api-key-here"
# GEMINI_API_KEY="alternative-env-name-same-purpose"

# דגם כללי לפרויקט (אופציונלי; ברירת מחדל מאי 2026: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
# GOOGLE_GENERATIVE_AI_MODEL=gemini-2.5-flash

# דגם לצ'אט NotebookLM (`/api/notebooklm/chat`). ברירת מחדל: gemini-2.5-flash
# GEMINI_NOTEBOOKLM_MODEL=gemini-2.5-flash

# Live (עוזר קולי): gemini-2.5-flash-native-audio-latest — ראה lib/gemini-model.ts
# GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-latest

# דגם למחברת ERP (נתיבים אחרים; לא חובה לווידג'ט OS)
# GEMINI_NOTEBOOK_MODEL=gemini-2.5-flash-lite
