{
  "name": "bsd-ybm-os",
  "version": "1.0.0",
  "private": true,
  "lint-staged": {
    "*.{ts,tsx}": "eslint --max-warnings 0 --no-warn-ignored"
  },
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "embed-pdf-fonts": "node scripts/embed-pdf-fonts.mjs",
    "marketing:hero-video": "node scripts/generate-marketing-hero-video.mjs",
    "marketing:hero-slideshow": "node scripts/generate-marketing-hero-slideshow.mjs",
    "build": "node scripts/prebuild.mjs && next build",
    "analyze": "ANALYZE=true node scripts/prebuild.mjs && ANALYZE=true next build",
    "prebuild:1": "node scripts/ensure-production-schema.mjs",
    "prebuild:2": "node scripts/check-env-essential.mjs",
    "prebuild:3": "node scripts/embed-pdf-fonts.mjs",
    "prebuild:4": "node scripts/prisma-generate-safe.mjs",
    "start": "next start",
    "test": "jest",
    "test:coverage": "jest --coverage --runInBand",
    "test:coverage:ci": "jest --coverage --maxWorkers=50%",
    "test:e2e": "playwright test",
    "test:e2e:quality": "playwright test e2e/site-quality.spec.ts --project=chromium --project=mobile-chrome",
    "test:e2e:workspace": "playwright test e2e/workspace-automations.spec.ts e2e/workspace-a11y.spec.ts e2e/hubs.spec.ts e2e/auth-api-smoke.spec.ts --project=chromium",
    "test:e2e:project": "playwright test e2e/project-control-center.spec.ts e2e/project-workflow.spec.ts e2e/mobile-workspace-windows.spec.ts --project=chromium --project=mobile-chrome",
    "test:e2e:crm": "playwright test e2e/crm-project-bridge.spec.ts --project=chromium",
    "test:e2e:ci-gate": "playwright test e2e/site-quality.spec.ts e2e/workspace-automations.spec.ts e2e/workspace-a11y.spec.ts e2e/hubs.spec.ts e2e/auth-api-smoke.spec.ts e2e/project-control-center.spec.ts e2e/project-workflow.spec.ts e2e/mobile-workspace-windows.spec.ts e2e/crm-project-bridge.spec.ts e2e/product-brochure-finance-export.spec.ts e2e/product-brochure-crm.spec.ts e2e/product-brochure-archive-bulk.spec.ts e2e/google-calendar-sync.spec.ts e2e/growth-public.spec.ts e2e/knowledge-vault-search.spec.ts e2e/boq-agent-api.spec.ts e2e/accounting-export.spec.ts e2e/office-expenses.spec.ts --project=chromium --project=mobile-chrome",
    "test:e2e:brochure": "playwright test e2e/product-brochure-finance-export.spec.ts e2e/product-brochure-crm.spec.ts e2e/product-brochure-archive-bulk.spec.ts e2e/google-calendar-sync.spec.ts --project=chromium",
    "lint": "eslint . --max-warnings 0",
    "audit:api": "node scripts/audit-api-routes.mjs",
    "audit:rate-limits": "node scripts/audit-rate-limits.mjs",
    "audit:process-env": "node scripts/audit-process-env.mjs",
    "audit:hebrew-hardcode": "node scripts/check-hardcoded-hebrew.mjs",
    "verify": "npm run lint && npx tsc --noEmit && npm run audit:api && npm run audit:rate-limits && npm test",
    "verify:all": "npm run verify && playwright test --project=chromium --project=mobile-chrome --workers=1 --retries=1",
    "premerge": "npm run verify:all",
    "verify:e2e:seeded": "npm run seed:test && playwright test",
    "postinstall": "prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:execute:subscription-v2": "dotenv -e .env.local -- prisma db execute --file prisma/migrations/manual_subscription_v2.sql --schema prisma/schema.prisma",
    "db:execute:rename-scans": "dotenv -e .env.local -- prisma db execute --file prisma/migrations/rename_scans_remaining_and_invitations.sql --schema prisma/schema.prisma",
    "db:execute:org-invite": "dotenv -e .env.local -- prisma db execute --file prisma/migrations/add_organization_invite.sql --schema prisma/schema.prisma",
    "db:execute:document-draft": "dotenv -e .env.local -- prisma db execute --file prisma/migrations/add_document_draft.sql --schema prisma/schema.prisma",
    "db:execute:backfill-construction": "dotenv -e .env.local -- prisma db execute --file prisma/migrations/backfill_org_construction_industry.sql --schema prisma/schema.prisma",
    "db:execute:knowledge-vault": "dotenv -e .env.local -- prisma db execute --file prisma/migrations/20260519140000_knowledge_vault/migration.sql --schema prisma/schema.prisma",
    "db:migrate": "dotenv -e .env.local -- prisma migrate deploy",
    "db:migrate:dev": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:status": "dotenv -e .env.local -- node scripts/db-migrate-status-neon.mjs",
    "i18n:parity": "node scripts/i18n-key-parity.mjs",
    "load-test:smoke": "node scripts/load-test.mjs",
    "lib:line-count": "node scripts/lib-line-count.mjs --min 300",
    "ops:neon-dr-drill": "node scripts/neon-dr-drill.mjs",
    "ops:10-10-status": "node scripts/refresh-10-10-status.mjs",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:migrate:prod": "dotenv -e .env.local -- prisma migrate deploy",
    "vercel:integration:posthog": "vercel integration add posthog -m data_region=EU -e production --plan posthog-usage-based",
    "vercel:env:push:posthog": "node scripts/vercel-push-env-from-local.mjs --only=NEXT_PUBLIC_POSTHOG_KEY,NEXT_PUBLIC_POSTHOG_HOST,NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN",
    "broadcast:inapp": "dotenv -e .env.local -- node scripts/broadcast-inapp.mjs",
    "db:wipe:keep-owner": "dotenv -e .env.local -- node scripts/wipe-postgres-keep-owner.mjs",
    "db:delete-user": "dotenv -e .env.local -- node scripts/delete-user-by-email.mjs",
    "seed:test": "node scripts/seed-test-data.mjs",
    "vercel:env:pull": "vercel env pull .env.vercel.pull --yes",
    "env:normalize": "node scripts/normalize-env-local.mjs",
    "vercel:env:wipe": "node scripts/vercel-wipe-env.mjs",
    "vercel:env:resync": "node scripts/vercel-resync-env-from-local.mjs",
    "vercel:env:overwrite-all": "node scripts/vercel-overwrite-all-env-from-local.mjs",
    "vercel:env:push": "node scripts/vercel-push-env-from-local.mjs",
    "vercel:env:push:core": "node scripts/vercel-push-env-from-local.mjs --only=DATABASE_URL,DIRECT_URL,NEXTAUTH_SECRET,NEXTAUTH_URL,AUTH_URL,GOOGLE_GENERATIVE_AI_API_KEY,GEMINI_API_KEY,NEXT_PUBLIC_VAT_RATE",
    "vercel:env:push:essential": "node scripts/vercel-push-env-from-local.mjs --only=DATABASE_URL,DIRECT_URL,NEXTAUTH_SECRET,NEXTAUTH_URL,AUTH_URL,GOOGLE_GENERATIVE_AI_API_KEY,GEMINI_API_KEY",
    "vercel:env:push:stack": "node scripts/vercel-push-env-from-local.mjs --only=DATABASE_URL,NEXTAUTH_SECRET,NEXTAUTH_URL,AUTH_URL,GOOGLE_CLIENT_ID,GOOGLE_CLIENT_SECRET,GOOGLE_GENERATIVE_AI_API_KEY,NEXT_PUBLIC_SITE_URL,NEXT_PUBLIC_API_URL",
    "vercel:env:push:auth": "node scripts/vercel-push-env-from-local.mjs --only=NEXTAUTH_URL,AUTH_URL,NEXT_PUBLIC_SITE_URL,NEXT_PUBLIC_API_URL",
    "vercel:env:push:mail": "node scripts/vercel-push-mail-env.mjs",
    "vercel:deploy:prod": "vercel deploy --prod --yes",
    "check:deploy": "node scripts/check-neon-vercel-prereqs.mjs",
    "env:check": "node scripts/check-env-essential.mjs",
    "test:email": "node scripts/test-email.mjs",
    "gemini:validate": "node scripts/validate-gemini-env.mjs",
    "neon:ensure-direct": "node scripts/ensure-neon-direct-env.mjs",
    "db:test-connection": "dotenv -e .env.local -- node scripts/test-db-connection.mjs",
    "vercel:env:pull:prod": "vercel env pull .env.vercel.prod --environment=production --yes",
    "db:sync-from-vercel": "node scripts/sync-db-env-from-vercel-pull.mjs",
    "db:fix-migrations": "dotenv -e .env.local -- node scripts/fix-prisma-migrations-neon.mjs",
    "db:repair-migrations": "dotenv -e .env.local -- node scripts/repair-failed-prisma-migrations.mjs",
    "icons:generate": "node scripts/generate-pwa-icons.mjs",
    "i18n:construction-trades": "node scripts/build-construction-trade-locales.mjs",
    "tutorials:encode": "node scripts/generate-tutorial-videos.mjs",
    "lighthouse:sample": "node scripts/lighthouse-sample.mjs",
    "lighthouse:matrix": "node scripts/lighthouse-site-matrix.mjs",
    "lighthouse:matrix:prod": "node scripts/lighthouse-site-matrix.mjs --base=https://www.bsd-ybm.co.il",
    "lighthouse:auth-setup": "node scripts/lighthouse-auth-setup.mjs",
    "lighthouse:report": "node scripts/lighthouse-report-summary.mjs",
    "lighthouse:auth:matrix": "node scripts/lighthouse-auth-setup.mjs && node scripts/lighthouse-site-matrix.mjs --tier=auth --priority=P0 --strategy=both",
    "product-brochure:capture": "npx tsx scripts/capture-product-brochure-screenshots.ts",
    "product-brochure:capture:v2": "dotenv -e .env.local -- npx tsx scripts/capture-product-brochure-v2.ts",
    "marketing:sync-screenshots": "node scripts/sync-marketing-screenshots.mjs",
    "marketing:capture-live-demo": "npx tsx scripts/capture-product-brochure-v2.ts && node scripts/sync-marketing-screenshots.mjs",
    "product-brochure:pdf": "dotenv -e .env.local -- npx tsx scripts/generate-product-brochure-pdf.ts",
    "product-brochure:v2-pdf": "npx tsx scripts/generate-product-brochure-v2-pdf.ts",
    "system-spec:pdf": "npx tsx scripts/generate-system-spec-pdf.ts",
    "marketing:onepagers": "npx tsx scripts/generate-marketing-onepagers.ts",
    "docs:marketing-pdf": "npm run marketing:onepagers && npm run product-brochure:pdf && npm run product-brochure:v2-pdf",
    "product-brochure:build": "npm run product-brochure:capture && npm run product-brochure:pdf",
    "brand:prepare-assets": "node scripts/prepare-brand-assets.mjs",
    "load-test": "node scripts/load-test.mjs",
    "prepare": "husky"
  },
