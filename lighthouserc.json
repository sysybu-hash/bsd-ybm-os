{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start",
      "startServerReadyPattern": "Ready",
      "startServerReadyTimeout": 180000,
      "url": ["http://localhost:3000/"],
      "numberOfRuns": 3,
      "puppeteerScript": "./scripts/lhci-warmup.cjs",
      "settings": {
        "formFactor": "mobile",
        "screenEmulation": { "mobile": true },
        "throttlingMethod": "simulate"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.80, "aggregationMethod": "median-run" }],
        "categories:accessibility": ["error", { "minScore": 0.99 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.99 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 5000 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.05 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 200 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
